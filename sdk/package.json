{
  "name": "@pixai/sdk",
  "version": "0.1.0",
  "description": "PIXAI SDK — generate game assets (2D sprites, 3D models) on Solana from code. Handles Sign-In with Solana auth + $PIXAI/SOL payment automatically.",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": ["pixai", "solana", "game-assets", "ai", "sprites", "3d", "spine"],
  "license": "MIT",
  "dependencies": {
    "@noble/curves": "^1.9.7",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0"
  },
  "engines": { "node": ">=18" }
}
